# =============================================================================
#  LLM Proxy Hub — Environment Configuration
#  
#  Copy this file to .env and fill in your values.
#  
#    cp .env.example .env
#  
#  ⚠️  Never commit your .env file. It is already in .gitignore.
# =============================================================================


# -----------------------------------------------------------------------------
#  SERVER
# -----------------------------------------------------------------------------

# Port the proxy listens on.
# Claude Code must point to this: ANTHROPIC_BASE_URL=http://localhost:<PORT>
PORT=8088

# Log verbosity: debug | info | warn | error
LOG_LEVEL=info


# -----------------------------------------------------------------------------
#  MODEL MAPPING
#
#  Map Claude model aliases → your provider and model.
#  Format:  MAP_<ALIAS>=<provider>:<model-name>
#
#  Claude Code sends these aliases in every request:
#    claude-opus-4-6       →  your most capable model
#    claude-sonnet-4-6     →  your default workhorse
#    claude-haiku-4-5      →  your fastest / cheapest model
#
#  Provider tokens: groq | openrouter | deepseek | nvidia | ollama | ollama-cloud
#
#  Examples:
#    MAP_CLAUDE_SONNET_4_6=ollama-cloud:deepseek-v3.1:671b-cloud
#    MAP_CLAUDE_SONNET_4_6=ollama-cloud:deepseek-v3.1:671b-cloud
#    MAP_CLAUDE_SONNET_4_6=ollama-cloud:deepseek-v3.1:671b-cloud
# -----------------------------------------------------------------------------

MAP_CLAUDE_OPUS_4_6=ollama-cloud:deepseek-v3.1:671b-cloud
MAP_CLAUDE_SONNET_4_6=ollama-cloud:deepseek-v3.1:671b-cloud
MAP_CLAUDE_HAIKU_4_5=ollama-cloud:deepseek-v3.1:671b-cloud

# Catch-all for any Claude model alias not listed above.
DEFAULT_PROVIDER=ollama-cloud:deepseek-v3.1:671b-cloud
# Automatically used if the primary model returns a 5xx error.
# Set to a different provider/model for true redundancy.
FALLBACK_PROVIDER=groq:llama-3.1-8b-instant


# -----------------------------------------------------------------------------
#  API KEYS
#  Only fill in keys for the providers you actually use.
# -----------------------------------------------------------------------------

# ── Groq ─────────────────────────────────────────────────────────────────────
# Free tier available. Fast inference. Best for: Llama 3, Qwen, Mixtral.
# Get key → https://console.groq.com/keys
GROQ_API_KEY=

# ── OpenRouter ───────────────────────────────────────────────────────────────
# Gateway to 200+ models (GPT-4o, Claude, Mistral, DeepSeek, and more).
# Get key → https://openrouter.ai/keys
OPENROUTER_API_KEY=

# ── DeepSeek ─────────────────────────────────────────────────────────────────
# Extremely cheap. Best for: DeepSeek-V3, DeepSeek-R1.
# Get key → https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=

# ── NVIDIA NIM ───────────────────────────────────────────────────────────────
# Free tier available. Best for: Llama 3.1 405B, Nemotron.
# Get key → https://build.nvidia.com
NVIDIA_NIM_API_KEY=

# ── Ollama Cloud ─────────────────────────────────────────────────────────────
# Hosted Ollama. Best for: any model you've pulled locally, now in the cloud.
# Get key → https://ollama.com
OLLAMA_API_KEY=

# ── Ollama Local ─────────────────────────────────────────────────────────────
# No key needed. Runs entirely on your machine.
# Change this only if your Ollama instance is not on the default port.
OLLAMA_BASE_URL=http://localhost:11434


# -----------------------------------------------------------------------------
#  ADVANCED TUNING
#  Change as you want 
# -----------------------------------------------------------------------------

# Maximum tokens to request from the provider per completion.
MAX_TOKENS=8192

# How long to wait for a provider response before timing out (milliseconds).
REQUEST_TIMEOUT_MS=60000

# Number of retry attempts on transient network errors before falling back.
MAX_RETRIES=2
